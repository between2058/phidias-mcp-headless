# -------- Phidias backend API URLs --------
# Leave empty to use the built-in defaults (172.18.245.177 internal network).
# Override these if you are running backends at different hosts.

QWEN_API_URL=
TRELLIS2_API_URL=
RECONVIAGEN_API_URL=
P3SAM_API_URL=
ARTICULATION_API_URL=

# -------- Articulation physics converter --------
# Absolute path to the Python script that converts the backend's USDZ output
# into a phidias.physics.v1 JSON. Defaults to the bundled copy at
# `<package>/scripts/usdz_to_phidias_physics.py`. Override only if you want to
# point at a fork.
#
# Requires `python3` and `usdcat` (from the OpenUSD toolchain or Xcode CLT on
# macOS) to be on PATH at runtime.
PHIDIAS_PHYSICS_CONVERTER_PATH=

# -------- Transport mode --------
# If MCP_HTTP_PORT is set → server runs in HTTP mode (Streamable HTTP transport).
# If it is unset/empty   → server runs in stdio mode (default, for Claude Code spawn).
#
# MCP_HTTP_PORT   TCP port to listen on, e.g. 7777
# MCP_HTTP_HOST   Bind address (default: 0.0.0.0 — WARNING: accepts connections from anyone on the network)
# MCP_HTTP_TOKEN  Optional Bearer token; if set, clients must send "Authorization: Bearer <token>".
#                 Strongly recommended when bound to 0.0.0.0.
#
# Note: this .env file is NOT auto-loaded by the server.
# When launched via Claude Code, pass these through the `env` block in ~/.claude.json.
# When launched manually, export them in your shell or prefix the command (e.g. MCP_HTTP_PORT=7777 node dist/index.js).

MCP_HTTP_PORT=
MCP_HTTP_HOST=
MCP_HTTP_TOKEN=
